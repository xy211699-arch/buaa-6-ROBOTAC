+def _safe_normalize(vec: torch.Tensor, fallback: torch.Tensor) -> torch.Tensor:
+  norm = torch.linalg.norm(vec)
+  if norm < 1e-8:
+    return fallback
+  return vec / norm
+
+def _rotation_matrix_to_quat(rot: torch.Tensor) -> torch.Tensor:
+  """Convert 3x3 rotation matrix to (w, x, y, z) quaternion."""
+  trace = rot[0, 0] + rot[1, 1] + rot[2, 2]
+  if trace > 0.0:
+    s = torch.sqrt(trace + 1.0) * 2.0
+    qw = 0.25 * s
+    qx = (rot[2, 1] - rot[1, 2]) / s
+    qy = (rot[0, 2] - rot[2, 0]) / s
+    qz = (rot[1, 0] - rot[0, 1]) / s
+  elif rot[0, 0] > rot[1, 1] and rot[0, 0] > rot[2, 2]:
+    s = torch.sqrt(1.0 + rot[0, 0] - rot[1, 1] - rot[2, 2]) * 2.0
+    qw = (rot[2, 1] - rot[1, 2]) / s
+    qx = 0.25 * s
+    qy = (rot[0, 1] + rot[1, 0]) / s
+    qz = (rot[0, 2] + rot[2, 0]) / s
+  elif rot[1, 1] > rot[2, 2]:
+    s = torch.sqrt(1.0 + rot[1, 1] - rot[0, 0] - rot[2, 2]) * 2.0
+    qw = (rot[0, 2] - rot[2, 0]) / s
+    qx = (rot[0, 1] + rot[1, 0]) / s
+    qy = 0.25 * s
+    qz = (rot[1, 2] + rot[2, 1]) / s
+  else:
+    s = torch.sqrt(1.0 + rot[2, 2] - rot[0, 0] - rot[1, 1]) * 2.0
+    qw = (rot[1, 0] - rot[0, 1]) / s
+    qx = (rot[0, 2] + rot[2, 0]) / s
+    qy = (rot[1, 2] + rot[2, 1]) / s
+    qz = 0.25 * s
+  quat = torch.tensor([qw, qx, qy, qz], device=rot.device, dtype=rot.dtype)
+  return _safe_normalize(
+    quat,
+    torch.tensor([1.0, 0.0, 0.0, 0.0], device=rot.device, dtype=rot.dtype),
+  )
+
+
+class _PunchTracker:
+  """Single fixed target tracker with auto hand selection and force monitoring."""
+
+  def __init__(
+    self,
+    env: ManagerBasedRlEnv,
+    tip_offset: tuple[float, float, float] = (0.15, 0.02, 0.0),
+    punch_hand: Literal["auto", "left", "right"] = "auto",
+  ):
+    self.env = env
+    self.motion_cmd = env.command_manager.get_term("motion")
+    self.target = env.scene.entities.get("punch_target")
+    self.user_hand = punch_hand
+
+    self.right_tip_offset = torch.tensor(tip_offset, device=env.device)
+    self.left_tip_offset = torch.tensor(
+      (tip_offset[0], -tip_offset[1], tip_offset[2]), device=env.device
+    )
+
+    self.target_half_thickness = 0.00
+    self.target_half_height = 0.16
+    self.target_quat = torch.tensor([1.0, 0.0, 0.0, 0.0], device=env.device)
+    self.target_center = torch.tensor([0.50, 0.00, 0.98], device=env.device)
+
+    self.selected_hand: Literal["left", "right"] = "right"
+    self.max_force = 0.0
+    self.episode_max_force = 0.0
+    self.start_to_target_distance = 0.0
+    self.has_contact = False
+
+    self.sensors: dict[str, list[ContactSensor]] = {"left": [], "right": []}
+    for name, sensor in env.scene.sensors.items():
+      if not isinstance(sensor, ContactSensor) or "fist_target" not in name:
+        continue
+      if "left" in name:
+        self.sensors["left"].append(sensor)
+      elif "right" in name:
+        self.sensors["right"].append(sensor)
+
+    body_names = self.motion_cmd.cfg.body_names
+    self._left_idx = body_names.index("left_wrist_yaw_link")
+    self._right_idx = body_names.index("right_wrist_yaw_link")
+    anchor_name = self.motion_cmd.cfg.anchor_body_name
+    self._anchor_idx = body_names.index(anchor_name) if anchor_name in body_names else 0
+
+  def _motion_steps(self) -> int:
+    total = self.motion_cmd.motion.time_step_total
+    if isinstance(total, torch.Tensor):
+      return int(total.item())
+    return int(total)
+
+  def _tip_traj(self, body_idx: int, tip_offset: torch.Tensor) -> torch.Tensor:
+    steps = self._motion_steps()
+    body_pos = self.motion_cmd.motion.body_pos_w[:steps, body_idx]
+    body_quat = self.motion_cmd.motion.body_quat_w[:steps, body_idx]
+    offsets = tip_offset.unsqueeze(0).expand(steps, -1)
+    return body_pos + quat_apply(body_quat, offsets) + self.env.scene.env_origins[0]
+
+  def _plan_target_pose(self):
+    start_base = (
+      self.motion_cmd.motion.body_pos_w[0, self._anchor_idx] + self.env.scene.env_origins[0]
+    )
+    left_tip_traj = self._tip_traj(self._left_idx, self.left_tip_offset)
+    right_tip_traj = self._tip_traj(self._right_idx, self.right_tip_offset)
+
+    left_reach = torch.linalg.norm(left_tip_traj - start_base, dim=1)
+    right_reach = torch.linalg.norm(right_tip_traj - start_base, dim=1)
+    left_max = float(left_reach.max().item())
+    right_max = float(right_reach.max().item())
+
+    if self.user_hand == "left":
+      chosen_hand = "left"
+    elif self.user_hand == "right":
+      chosen_hand = "right"
+    else:
+      chosen_hand = "left" if left_max > right_max else "right"
+    self.selected_hand = chosen_hand
+
+    tip_traj = left_tip_traj if chosen_hand == "left" else right_tip_traj
+    max_idx = int(torch.argmax(left_reach if chosen_hand == "left" else right_reach).item())
+    max_tip = tip_traj[max_idx]
+    prev_idx = max(0, max_idx - 4)
+    dir_vec = max_tip - tip_traj[prev_idx]
+    if torch.linalg.norm(dir_vec) < 1e-6:
+      dir_vec = max_tip - tip_traj[0]
+    fallback = torch.tensor([1.0, 0.0, 0.0], device=self.env.device)
+    normal = dir_vec.clone()
+    normal[2] = 0.0
+    normal = _safe_normalize(normal, fallback)
+    up = torch.tensor([0.0, 0.0, 1.0], device=self.env.device)
+    if abs(float(torch.dot(normal, up).item())) > 0.95:
+      normal = fallback
+    tangent = _safe_normalize(
+      torch.cross(up, normal, dim=0),
+      torch.tensor([0.0, 1.0, 0.0], device=self.env.device),
+    )
+    vertical = _safe_normalize(torch.cross(normal, tangent, dim=0), up)
+    rot = torch.stack([normal, tangent, vertical], dim=1)
+    self.target_quat = _rotation_matrix_to_quat(rot)
+    self.target_center = max_tip + normal * self.target_half_thickness
+    self.start_to_target_distance = float(torch.linalg.norm(self.target_center - start_base).item())
+
+    hand_label = "左拳" if chosen_hand == "left" else "右拳"
+    print(
+      f"[PunchForce] 自动选手结果: {hand_label} "
+      f"(left={left_max:.3f}m, right={right_max:.3f}m)"
+    )
+
+  def _write_target_pose(self):
+    if self.target is None:
+      return
+    pose = torch.cat([self.target_center, self.target_quat]).unsqueeze(0)
+    self.target.write_mocap_pose_to_sim(pose)
+
+  def on_step(self):
+    self._write_target_pose()
+    total_force = 0.0
+    any_contact = False
+    for sensor in self.sensors[self.selected_hand]:
+      data = sensor.data
+      if data.found is None or data.force is None:
+        continue
+      found = data.found[0]
+      force = data.force[0]
+      for i in range(found.shape[0]):
+        if found[i] <= 0:
+          continue
+        fmag = torch.linalg.norm(force[i]).item()
+        if fmag > 0:
+          any_contact = True
+          total_force = max(total_force, fmag)
+
+    if any_contact and total_force > self.episode_max_force:
+      self.episode_max_force = total_force
+      self.max_force = max(self.max_force, total_force)
+      self.has_contact = True
+      hand_label = "左拳" if self.selected_hand == "left" else "右拳"
+      print(f"[PunchForce] {hand_label}力度：{total_force:.2f} N")
+
+  def on_reset(self):
+    if self.has_contact:
+      hand_label = "左拳" if self.selected_hand == "left" else "右拳"
+      print(
+        f"[PunchForce] {hand_label} episode summary - Max force: {self.episode_max_force:.2f} N"
+      )
+    self.episode_max_force = 0.0
+    self.has_contact = False
+    self._plan_target_pose()
+    self._write_target_pose()
+
+  @property
+  def label_text(self) -> str:
+    hand_label = "左拳" if self.selected_hand == "left" else "右拳"
+    return (
+      f"{hand_label} 最大击打力度: {self.max_force:.2f} N"
+      f"<br>起始位置到拳靶距离约: {self.start_to_target_distance:.3f} m"
+    )
+
+  @property
+  def label_pos(self) -> tuple[float, float, float]:
+    pos = self.target_center + torch.tensor(
+      [0.0, 0.0, self.target_half_height + 0.10], device=self.env.device
+    )
+    return (float(pos[0].item()), float(pos[1].item()), float(pos[2].item()))
+
