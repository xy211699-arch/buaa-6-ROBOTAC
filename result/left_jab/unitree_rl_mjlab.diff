+def _get_wall_logo_texture_file() -> str | None:
+  """Return a contrast-enhanced wall texture file path."""
+  if not _WALL_LOGO_PNG.exists():
+    return None
+  try:
+    from PIL import Image, ImageEnhance
+  except Exception:
+    return str(_WALL_LOGO_PNG)
+
+  output = _WALL_LOGO_PNG.with_name(f"{_WALL_LOGO_PNG.stem}_contrast.png")
+  try:
+    img = Image.open(_WALL_LOGO_PNG).convert("RGB")
+    # Slightly increase contrast for clearer wall presentation.
+    img = ImageEnhance.Contrast(img).enhance(1.35)
+    img.save(output)
+    return str(output)
+  except Exception:
+    return str(_WALL_LOGO_PNG)
+
+
+def _get_punch_target_spec() -> mujoco.MjSpec:
+  """Create a single punch target as a cylinder with its flat face toward impact."""
+  spec = mujoco.MjSpec()
+  target = spec.worldbody.add_body(name="punch_target")
+  geom = target.add_geom(
+    name="target_pad",
+    type=mujoco.mjtGeom.mjGEOM_CYLINDER,
+    # size=[radius, half-length], so total thickness is 0.10m.
+    size=[0.16, 0.05],
+  )
+  # MuJoCo cylinder axis is local +Z; rotate geom so cylinder axis aligns with body +X.
+  # Then the runtime body orientation in play.py keeps the cylinder flat face toward punch.
+  geom.quat = [0.7071068, 0.0, -0.7071068, 0.0]
+  geom.rgba = [0.9, 0.1, 0.1, 1.0]
+  geom.mass = 2.0
+  geom.friction = np.array([0.8, 0.05, 0.01])
+  geom.solimp = np.array([0.9, 0.95, 0.001, 0.0, 0.0])
+  geom.solref = np.array([0.01, 1.0])
+  force_site = target.add_site(name="force_sensor", pos=[0.0, 0.0, 0.18], size=[1e-6])
+  force_site.rgba = [1.0, 1.0, 1.0, 0.0]
+  return spec
+
+
+def _get_training_wall_spec() -> mujoco.MjSpec:
+  """Create a white training wall: length 10m, height 2m."""
+  spec = mujoco.MjSpec()
+  wall = spec.worldbody.add_body(name="training_wall")
+  geom = wall.add_geom(
+    name="training_wall_geom",
+    type=mujoco.mjtGeom.mjGEOM_BOX,
+    # half-sizes: length=10m, thickness=0.10m, height=2m
+    size=[5.0, 0.05, 1.0],
+  )
+  geom.rgba = [1.0, 1.0, 1.0, 1.0]
+  geom.friction = np.array([0.8, 0.05, 0.01])
+  geom.solimp = np.array([0.9, 0.95, 0.001, 0.0, 0.0])
+  geom.solref = np.array([0.01, 1.0])
+
+  # Add a MuJoCo-native textured logo plane so it stays fixed in world coordinates.
+  logo_tex_file = _get_wall_logo_texture_file()
+  if logo_tex_file is not None and _WALL_LOGO_MESH.exists():
+    spec.add_texture(
+      name="training_wall_logo_tex",
+      type=mujoco.mjtTexture.mjTEXTURE_2D,
+      file=logo_tex_file,
+      nchannel=3,
+      vflip=0,
+    )
+    spec.add_material(
+      name="training_wall_logo_mat",
+      # Bind texture to both USER(role=0) and RGB(role=1) so Viser path can read it.
+      textures=["training_wall_logo_tex", "training_wall_logo_tex"],
+      texuniform=0,
+      texrepeat=[1.0, 1.0],
+      emission=1.0,
+      specular=0.0,
+      reflectance=0.0,
+      rgba=[1.0, 1.0, 1.0, 1.0],
+    )
+    spec.add_mesh(
+      name="training_wall_logo_mesh",
+      file=str(_WALL_LOGO_MESH),
+      inertia=mujoco.mjtMeshInertia.mjMESH_INERTIA_SHELL,
+    )
+    logo_geom = wall.add_geom(
+      name="training_wall_logo_geom",
+      type=mujoco.mjtGeom.mjGEOM_MESH,
+      meshname="training_wall_logo_mesh",
+      # Center the logo on wall and keep slight offset to avoid z-fighting.
+      pos=[0.0, -0.056, 0.0],
+    )
+    logo_geom.rgba = [1.0, 1.0, 1.0, 1.0]
+    logo_geom.material = "training_wall_logo_mat"
+    logo_geom.contype = 0
+    logo_geom.conaffinity = 0
+
+  return spec
+
